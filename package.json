{
  "name": "quiznova-backend",
  "version": "1.0.0",
  "description": "Production-grade Express/MySQL backend for QuizNova.",
  "main": "backend/server.js",
  "scripts": {
    "dev": "nodemon backend/server.js",
    "start": "node backend/server.js",
    "db:migrate": "mysql -u $MYSQL_USER -p$MYSQL_PASSWORD $MYSQL_DATABASE < backend/database/schema.sql"
